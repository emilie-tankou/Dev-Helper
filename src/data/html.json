        "cmd": "align-items: center | stretch;",
        "desc": "Aligne les éléments sur l'axe secondaire"
      },
      {
        "id": 17,
        "cmd": "gap: 16px;",
        "desc": "Espace entre les éléments flex"
      },
      {
        "id": 18,
        "cmd": "flex: 1;",
        "desc": "L'élément prend tout l'espace disponible"
      }
    ]
  },
  {
    "category": "CSS — Grid",
    "items": [
      {
        "id": 19,
        "cmd": "display: grid;",
        "desc": "Active le modèle CSS Grid"
      },
      {
        "id": 20,
        "cmd": "grid-template-columns: repeat(3, 1fr);",
        "desc": "Crée 3 colonnes de taille égale"
      },
      {
        "id": 21,
        "cmd": "grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));",
        "desc": "Grille responsive sans media queries"
      },
      {
        "id": 22,
        "cmd": "grid-column: span 2;",
        "desc": "Un élément occupe 2 colonnes"
      }
    ]
  },
